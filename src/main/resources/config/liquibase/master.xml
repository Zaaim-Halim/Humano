<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
    <!--
        Per-DBMS column type properties.

        UUIDs are stored as 16-byte binary (not 36-char text) on every dialect:
          mysql/mariadb/mssql/h2 → BINARY(16)   (2.25× smaller than VARCHAR(36) and
                                                 indexed as fixed-width bytes)
          postgresql              → BYTEA       (paired with hibernate
                                                 preferred_uuid_jdbc_type=BINARY)
          oracle                  → RAW(16)
        IDs are generated by @UuidGenerator(style = TIME) in the entity layer, which
        emits RFC 4122 v1 (time-based) UUIDs. NOTE: v1 puts the fast-changing
        `time_low` bytes first, so these are NOT binary-sortable — the storage-size
        win holds, but B-tree clustering by insertion time does not. Migrate to a
        custom v7 generator if/when clustering becomes a measured concern.
    -->
    <property name="now" value="now()" dbms="h2"/>
    <property name="floatType" value="float4" dbms="h2"/>
    <property name="uuidType" value="BINARY(16)" dbms="h2"/>
    <property name="datetimeType" value="datetime(6)" dbms="h2"/>
    <property name="timeType" value="time(6)" dbms="h2"/>
    <property name="clobType" value="clob" dbms="h2"/>
    <property name="blobType" value="blob" dbms="h2"/>

    <property name="now" value="now()" dbms="mysql,mariadb"/>
    <property name="floatType" value="float" dbms="mysql,mariadb"/>
    <property name="clobType" value="clob" dbms="mysql,mariadb"/>
    <property name="blobType" value="longblob" dbms="mysql,mariadb"/>
    <property name="uuidType" value="BINARY(16)" dbms="mysql,mariadb"/>
    <property name="datetimeType" value="datetime(6)" dbms="mysql,mariadb"/>
    <property name="timeType" value="time(6)" dbms="mysql,mariadb"/>

    <property name="uuidType" value="BYTEA" dbms="postgresql"/>
    <property name="uuidType" value="BINARY(16)" dbms="mssql"/>
    <property name="uuidType" value="RAW(16)" dbms="oracle"/>

    <!--
        booleanType: matches what each dialect actually stores so Hibernate's
        ddl-auto=validate doesn't complain. MySQL/MariaDB's BOOLEAN is an alias for
        TINYINT(1), but Hibernate 6 expects JDBC type BIT for Booleans — so we use BIT(1)
        there. Oracle has no native boolean; use NUMBER(1).
    -->
    <property name="booleanType" value="BIT(1)" dbms="mysql,mariadb,h2,mssql"/>
    <property name="booleanType" value="BOOLEAN" dbms="postgresql"/>
    <property name="booleanType" value="NUMBER(1)" dbms="oracle"/>

    <!--
        jsonType: native JSON storage per dialect. Use with @JdbcTypeCode(SqlTypes.JSON)
        or Hibernate's JsonType on the entity side so reads/writes serialize correctly.
          mysql/mariadb → JSON         (MySQL 5.7+ / MariaDB 10.2+; validated, queryable)
          postgresql    → JSONB        (binary, indexable — prefer over JSON for filtering)
          h2            → JSON         (H2 2.x)
          mssql         → NVARCHAR(MAX) (SQL Server stores JSON as nvarchar + ISJSON checks)
          oracle        → CLOB         (Oracle 12c+ with IS JSON check; 21c+ has native JSON
                                        but CLOB stays the broadly-compatible choice)
    -->
    <property name="jsonType" value="JSON" dbms="mysql,mariadb,h2"/>
    <property name="jsonType" value="JSONB" dbms="postgresql"/>
    <property name="jsonType" value="NVARCHAR(MAX)" dbms="mssql"/>
    <property name="jsonType" value="CLOB" dbms="oracle"/>

    <include file="config/liquibase/changelog/master/00000000000000-master-changelog.xml" relativeToChangelogFile="false"/>
    <include file="config/liquibase/changelog/master/20260218-tenant-country-changelog.xml" relativeToChangelogFile="false"/>

    <!--  will add incremental liquibase changelogs here -->
</databaseChangeLog>
