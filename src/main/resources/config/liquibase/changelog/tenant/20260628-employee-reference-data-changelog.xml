    <changeSet id="tenant-employee-refdata-fks" author="halimzaaim">
        <addColumn tableName="employee">
            <column name="employment_type_id" type="${uuidType}"/>
            <column name="grade_id" type="${uuidType}"/>
            <column name="level_id" type="${uuidType}"/>
            <column name="category_id" type="${uuidType}"/>
            <column name="marital_status_id" type="${uuidType}"/>
            <column name="termination_reason_id" type="${uuidType}"/>
        </addColumn>
        <addForeignKeyConstraint baseColumnNames="employment_type_id" baseTableName="employee"
                                 constraintName="FK_EMPLOYEE_ON_EMPLOYMENT_TYPE" referencedColumnNames="id"
                                 referencedTableName="employment_type"/>
        <addForeignKeyConstraint baseColumnNames="grade_id" baseTableName="employee"
                                 constraintName="FK_EMPLOYEE_ON_GRADE" referencedColumnNames="id"
                                 referencedTableName="job_grade"/>
        <addForeignKeyConstraint baseColumnNames="level_id" baseTableName="employee"
                                 constraintName="FK_EMPLOYEE_ON_LEVEL" referencedColumnNames="id"
                                 referencedTableName="job_level"/>
        <addForeignKeyConstraint baseColumnNames="category_id" baseTableName="employee"
                                 constraintName="FK_EMPLOYEE_ON_CATEGORY" referencedColumnNames="id"
                                 referencedTableName="employee_category"/>
        <addForeignKeyConstraint baseColumnNames="marital_status_id" baseTableName="employee"
                                 constraintName="FK_EMPLOYEE_ON_MARITAL_STATUS" referencedColumnNames="id"
                                 referencedTableName="marital_status"/>
        <addForeignKeyConstraint baseColumnNames="termination_reason_id" baseTableName="employee"
                                 constraintName="FK_EMPLOYEE_ON_TERMINATION_REASON" referencedColumnNames="id"
                                 referencedTableName="termination_reason"/>
    </changeSet>

</databaseChangeLog>
