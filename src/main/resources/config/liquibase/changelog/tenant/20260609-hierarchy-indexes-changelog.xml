<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd"
    objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">

    <!--
        Indexes that back the materialized-path hierarchy reads.
        - *_path: prefix-LIKE 'root/%' subtree fetches go through these as range scans
                  instead of full table scans.
        - employee_unit_id: fused employees-in-unit-subtree query joins through this FK.
        - organizational_unit_parent_unit_id: direct sub-units lookup and validation.
    -->

    <!--
        path is VARCHAR(1000); under MySQL/MariaDB utf8mb4 a full-column index is 4000 bytes, over the
        3072-byte key limit (error 1071). Use a 255-char prefix index there (1020 bytes) — ample for the
        prefix-LIKE 'root/%' range scans this backs — and a plain index on dialects without that limit.
    -->
    <changeSet id="tenant-hierarchy-001-employee-path-idx" author="halimzaaim">
        <sql dbms="mysql,mariadb">CREATE INDEX idx_employee_path ON employee(path(255))</sql>
        <sql dbms="!mysql,!mariadb">CREATE INDEX idx_employee_path ON employee(path)</sql>
        <rollback>
            <dropIndex tableName="employee" indexName="idx_employee_path"/>
        </rollback>
    </changeSet>

    <changeSet id="tenant-hierarchy-002-employee-unit-idx" author="halimzaaim">
        <createIndex tableName="employee" indexName="idx_employee_unit_id">
            <column name="unit_id"/>
        </createIndex>
    </changeSet>

    <!-- Same VARCHAR(1000) utf8mb4 key-length limit as the employee path index above. -->
    <changeSet id="tenant-hierarchy-003-org-unit-path-idx" author="halimzaaim">
        <sql dbms="mysql,mariadb">CREATE INDEX idx_organizational_unit_path ON organizational_unit(path(255))</sql>
        <sql dbms="!mysql,!mariadb">CREATE INDEX idx_organizational_unit_path ON organizational_unit(path)</sql>
        <rollback>
            <dropIndex tableName="organizational_unit" indexName="idx_organizational_unit_path"/>
        </rollback>
    </changeSet>

    <changeSet id="tenant-hierarchy-004-org-unit-parent-idx" author="halimzaaim">
        <createIndex tableName="organizational_unit" indexName="idx_organizational_unit_parent_unit_id">
            <column name="parent_unit_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>